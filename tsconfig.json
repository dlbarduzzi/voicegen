{
  "compilerOptions": {
    "incremental": true,
    "target": "ES2017",
    "jsx": "react-jsx",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "module": "esnext",
    "moduleResolution": "bundler",
    "paths": {
      "@/*": [
        "./src/*"
      ]
    },
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true, // custom
    "allowJs": true,
    "strict": true,
    "strictNullChecks": true, // custom
    "noFallthroughCasesInSwitch": true, // custom
    "noImplicitAny": true, // custom
    "noUncheckedIndexedAccess": true, // custom
    "noUnusedLocals": true, // custom
    "noUnusedParameters": true, // custom
    "noEmit": true,
    "noUncheckedSideEffectImports": true, // custom
    "esModuleInterop": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": [
    "node_modules"
  ]
}
